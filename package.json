{
  "private": true,
  "name": "mowc",
  "version": "0.13.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build -w @mowc/shared && npm run build -w @mowc/server && npm run build -w @mowc/client",
    "test": "vitest run",
    "test:e2e": "npm run build && playwright test",
    "check": "eslint . && npm run check --workspaces --if-present",
    "start": "npm run start --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@playwright/test": "^1.61.1",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^3.20.0",
    "prettier": "^3.3.3",
    "sharp": "^0.35.3",
    "svelte-eslint-parser": "^1.8.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.1.0",
    "vitest": "^4.1.10"
  }
}
