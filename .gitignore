# Dependencies
node_modules/

# Build output
/dist/
/client/build/
/client/.svelte-kit/
/shared/dist/
/server/dist/
*.tsbuildinfo

# Runtime data (root-anchored: never use bare `data/`, it can match source dirs)
/data/
/config/

# Environment
.env
.env.*
!.env.example

# Editor / OS noise
.DS_Store
Thumbs.db
*.swp

# Test artifacts
/coverage/
/playwright-report/
/test-results/

# Copyrighted source material must never be committed.
# PDFs and extracted game text stay local; see docs/LICENSING.md.
*.pdf

# The private content-pack working area is local-only. The README there
# (process notes, no game text) is the one tracked exception so the
# conversion workflow lives in the repo.
/content-packs/private/*
!/content-packs/private/README.md
